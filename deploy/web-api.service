[Unit]
Description=Reservation Agent Web API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/ai-agents
EnvironmentFile=/root/ai-agents/.env
ExecStart=/usr/bin/python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
